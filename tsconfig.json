{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "types": ["cypress", "node"],
    "module": "Node16",
    "moduleResolution": "Node16",
    "allowJs": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "outDir": "dist",
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "**/*.ts",
    "**/*.js",
    "cypress.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
