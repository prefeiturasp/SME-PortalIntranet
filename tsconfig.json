{
  "compilerOptions": {
    "target": "es5",
    "lib": ["es5", "dom"],
    "types": ["cypress", "node"],
    "moduleResolution": "node",
    "allowJs": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "dist",
    "ignoreDeprecations": "6.0"
  },
  "include": ["**/*.ts", "**/*.js", "cypress.config.js"],
  "exclude": ["node_modules", "dist"]
}
